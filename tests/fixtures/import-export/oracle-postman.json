  "item": [
    {
      "name": "1. POST - Create Employee",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Test için sabit empNo kullan",
              "const empNo = 7;",
              "pm.environment.set('test_empNo', empNo);",
              "",
              "const body = {",
              "    'firstName': 'Eren',",
              "    'lastName': 'Dile',",
              "    'hireDate': '18-04-2020',",
              "    'gender': 'M',",
              "    'empNo': empNo,",
              "    'birthDate': '18-04-2001'",
              "};",
              "",
              "pm.environment.set('employee_body', JSON.stringify(body));",
              "console.log('Creating employee with empNo:', empNo);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('POST: Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "",
              "pm.test('POST: statusCode is 200', function () {",
              "    pm.expect(res.statusCode).to.eql(200);",
              "});",
              "",
              "pm.test('POST: statusDescription is OK', function () {",
              "    pm.expect(res.statusDescription).to.eql('OK');",
              "});",
              "",
              "pm.test('POST: No errors', function () {",
              "    pm.expect(res.errors).to.be.an('array').that.is.empty;",
              "});",
              "",
              "console.log('✅ Employee created successfully');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{employee_body}}"
        },
        "url": {
          "raw": "{{baseUrl}}/employee",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employee"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. GET - Read After Create",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const empNo = pm.environment.get('test_empNo');",
              "console.log('Reading employee with empNo:', empNo);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('GET #1: Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "",
              "pm.test('GET #1: statusCode is 200', function () {",
              "    pm.expect(res.statusCode).to.eql(200);",
              "});",
              "",
              "pm.test('GET #1: numRows is 1', function () {",
              "    pm.expect(res.numRows).to.eql(1);",
              "});",
              "",
              "pm.test('GET #1: data array has 1 employee', function () {",
              "    pm.expect(res.data).to.be.an('array').with.lengthOf(1);",
              "});",
              "",
              "const employee = res.data[0];",
              "",
              "pm.test('GET #1: Employee has correct empNo', function () {",
              "    pm.expect(employee.emp_no).to.eql(7);",
              "});",
              "",
              "pm.test('GET #1: Employee has correct firstName', function () {",
              "    pm.expect(employee.first_name).to.eql('Eren');",
              "});",
              "",
              "pm.test('GET #1: Employee has correct lastName', function () {",
              "    pm.expect(employee.last_name).to.eql('Dile');",
              "});",
              "",
              "pm.test('GET #1: Employee has correct gender', function () {",
              "    pm.expect(employee.gender).to.eql('M');",
              "});",
              "",
              "console.log('✅ Employee read successfully:', employee);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/employee?empNo={{test_empNo}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employee"
          ],
          "query": [
            {
              "key": "empNo",
              "value": "{{test_empNo}}"
            }
          ]
        }
      },
      "response": []
    },
