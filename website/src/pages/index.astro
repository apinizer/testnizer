---
import BaseLayout from '../layouts/BaseLayout.astro'
import GuaranteeCard from '../components/GuaranteeCard.astro'
import { icons } from '../components/icons'
import { fetchLatestRelease } from '../lib/latest-release'

const release = await fetchLatestRelease()

const guarantees = [
  {
    icon: icons.shieldOff,
    title: '100% Offline',
    body: 'Air-gapped networks supported. The app sends API requests only to the targets you configure — never to a vendor server. No login, no account, no telemetry.',
  },
  {
    icon: icons.hardDrive,
    title: 'Local Storage Only',
    body: 'Workspaces, projects, environments, history, certificates and secrets live in a single SQLite database on your disk. Move it, back it up, delete it — your call.',
  },
  {
    icon: icons.gitBranch,
    title: 'Internal Git & Local DB',
    body: 'Tests live next to your code in your existing Git repo. Built-in simple-git integration means collections branch and review through your normal PR pipeline.',
  },
  {
    icon: icons.lock,
    title: 'Zero Data Leakage',
    body: 'The renderer has CSP connect-src self — physically incapable of reaching the public internet. Every API call goes through an audited main-process IPC handler you control.',
  },
]

const protocols = [
  { icon: icons.globe, name: 'HTTP / REST', body: 'Methods, params, headers, body, cookies, mTLS, proxy, redirects, multipart with file upload, scripts, assertions.' },
  { icon: icons.fileCode, name: 'SOAP / WSDL', body: 'WSDL import (URL or file), manual envelope mode, SOAP 1.1 + 1.2, multi-service, multi-port.' },
  { icon: icons.cpu, name: 'gRPC', body: '.proto import, all four streaming modes, metadata, JSON skeleton from message fields.' },
  { icon: icons.radio, name: 'WebSocket', body: 'ws + wss, custom headers, JSON / text composer, message timeline.' },
  { icon: icons.arrowsLeftRight, name: 'Socket.IO', body: 'Connect with namespace + auth, emit events with a JSON payload, subscribe to any event name, watch the bidirectional timeline.' },
  { icon: icons.network, name: 'GraphQL', body: 'Query, mutation, subscription, schema introspection, variables JSON.' },
  { icon: icons.bot, name: 'AI Chat', body: '14 providers (OpenAI, Anthropic, Google, xAI, DeepSeek, Mistral, Groq…) plus Custom URL — streaming, multi-turn. Requests go directly to the provider you configure; this is the only feature that contacts an external server.' },
  { icon: icons.zap, name: 'Server-Sent Events', body: 'Long-lived streams with Last-Event-ID resume.' },
  { icon: icons.plug, name: 'MCP', body: 'Model Context Protocol client. Streamable HTTP, SSE, and stdio (local subprocess) transports. List tools advertised by the server, invoke them with JSON arguments, inspect results.' },
]

const tools = [
  'JWT debugger',
  'WS-Security workbench',
  'AES / RSA encrypt / decrypt',
  'XML Signature & Encryption',
  'JSON / XML formatters',
  'Base64 / URL / Hex encoders',
  'JSONPath / XPath / XSLT / Jolt',
  'Text diff',
]
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero-glow relative overflow-hidden border-b border-border">
    <div class="dot-grid absolute inset-0"></div>
    <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-24 text-center md:pt-28 md:pb-32">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-bg-soft px-3 py-1 text-xs font-medium text-text-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
        {release.tag} — free forever · a project by Apinizer
      </div>

      <h1 class="mx-auto max-w-4xl text-4xl font-semibold tracking-tight text-text md:text-6xl md:leading-[1.1]">
        The offline API client for teams requiring
        <span class="text-gradient">absolute data privacy.</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted">
        Testnizer is a free, fully offline desktop app for testing HTTP, SOAP, WebSocket, GraphQL, gRPC and SSE — built by <a href="https://apinizer.com" target="_blank" rel="noopener" class="underline decoration-dotted underline-offset-2 hover:text-text">Apinizer</a> for teams in banking, government, insurance and healthcare where production credentials and payloads <em>must never</em> leave the machine.
      </p>

      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/download"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-accent-hover"
        >
          <Fragment set:html={icons.download} />
          Download for macOS, Windows, Linux
        </a>
        <a
          href="/docs/getting-started"
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-bg px-5 py-3 text-sm font-medium text-text transition-colors hover:bg-bg-muted"
        >
          Read the docs
          <Fragment set:html={icons.arrowRight} />
        </a>
      </div>

      <p class="mt-5 text-xs text-text-soft">
        macOS (arm64 / x64) · Windows (x64 / arm64) · Linux (deb / AppImage)
      </p>

      <div class="mt-5 flex flex-wrap items-center justify-center gap-2">
        <a href="https://github.com/apinizer/testnizer-releases/releases" target="_blank" rel="noopener" aria-label="Latest release">
          <img src="https://img.shields.io/github/v/release/apinizer/testnizer-releases?label=latest%20release&color=3b82f6&style=flat-square" alt="Latest release" height="20" />
        </a>
        <a href="https://github.com/apinizer/testnizer-releases/releases" target="_blank" rel="noopener" aria-label="Total downloads">
          <img src="https://img.shields.io/github/downloads/apinizer/testnizer-releases/total?label=downloads&color=3b82f6&style=flat-square" alt="Total downloads" height="20" />
        </a>
        <a href="https://github.com/apinizer/testnizer-releases" target="_blank" rel="noopener" aria-label="GitHub stars">
          <img src="https://img.shields.io/github/stars/apinizer/testnizer-releases?label=stars&color=3b82f6&style=flat-square" alt="GitHub stars" height="20" />
        </a>
        <img src="https://img.shields.io/badge/telemetry-none-3b82f6?style=flat-square" alt="No telemetry" height="20" />
      </div>
    </div>
  </section>

  <!-- Product screenshot -->
  <section class="border-b border-border bg-bg-soft py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="overflow-hidden rounded-card border border-border bg-bg shadow-2xl shadow-blue-500/10 ring-1 ring-white/5">
        <img
          src="/testnizer-overview.png"
          alt="Testnizer running with the Swagger Petstore OpenAPI loaded — sidebar shows the imported endpoint tree, the request pane shows a POST /pet with a JSON body, the response pane shows a 200 OK with the returned pet object."
          width="1399"
          height="871"
          loading="eager"
          decoding="async"
          class="block h-auto w-full"
        />
      </div>
      <p class="mt-4 text-center text-sm text-text-soft">
        Imported a Swagger spec, ran a POST, got a 200. No account, no cloud sync, no telemetry.
      </p>
    </div>
  </section>

  <!-- The four guarantees -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent-text">The four guarantees</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-text md:text-4xl">
          Your data never leaves your machine.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          Not when you decode a JWT. Not when you sign an XML envelope. Not when you check for updates. Not ever.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
        {guarantees.map((g) => (
          <GuaranteeCard icon={g.icon} title={g.title} body={g.body} />
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="border-y border-border bg-bg-soft py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent-text">Why offline matters</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-text md:text-4xl">
          Where your data actually goes.
        </h2>
      </div>

      <div class="mt-12 overflow-hidden rounded-card border border-border bg-bg">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-bg-muted text-left">
              <th class="px-5 py-3.5 font-medium text-text-muted">Concern</th>
              <th class="px-5 py-3.5 font-medium text-text-muted">SaaS API clients</th>
              <th class="px-5 py-3.5 font-medium text-accent-text">Testnizer</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">Where collections live</td>
              <td class="px-5 py-3.5 text-text-muted">Vendor cloud workspace</td>
              <td class="px-5 py-3.5 text-text">Local SQLite on your disk</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">Where tokens are stored</td>
              <td class="px-5 py-3.5 text-text-muted">Synced to vendor servers</td>
              <td class="px-5 py-3.5 text-text">OS keychain (Keychain / DPAPI / libsecret)</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">JWT decode</td>
              <td class="px-5 py-3.5 text-text-muted">Web app sends token to a remote service</td>
              <td class="px-5 py-3.5 text-text">Local crypto — token stays in process</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">WS-Security sign / encrypt</td>
              <td class="px-5 py-3.5 text-text-muted">Online tools or separate desktop app</td>
              <td class="px-5 py-3.5 text-text">Built-in main process with xml-crypto + Node crypto</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">Telemetry</td>
              <td class="px-5 py-3.5 text-text-muted">On by default</td>
              <td class="px-5 py-3.5 text-text">None — and no opt-in either</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text">Air-gapped network</td>
              <td class="px-5 py-3.5 text-text-muted">Doesn't work</td>
              <td class="px-5 py-3.5 text-text">Works</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Protocols -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent-text">Protocols</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-text md:text-4xl">
          Test what enterprise systems actually run on.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          Not just REST. SOAP envelopes, gRPC streams, WebSocket sessions, and event streams — first-class, on-device.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-px overflow-hidden rounded-card border border-border bg-border md:grid-cols-2 lg:grid-cols-3">
        {protocols.map((p) => (
          <div class="bg-bg p-6">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent-light text-accent-text">
              <Fragment set:html={p.icon} />
            </div>
            <h3 class="mt-4 text-base font-semibold text-text">{p.name}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-text-muted">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools strip -->
  <section class="border-t border-border bg-bg-soft py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-accent-text">Built-in tools</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-text md:text-4xl">
            All the things you'd otherwise paste into jwt.io.
          </h2>
          <p class="mt-4 text-base leading-relaxed text-text-muted">
            Every utility runs on-device. No round-trips to a third-party site to "format your JSON" or "decode your token." If the network is off, the tools still work.
          </p>
        </div>
        <ul class="grid grid-cols-2 gap-2.5">
          {tools.map((t) => (
            <li class="flex items-center gap-2.5 rounded-lg border border-border bg-bg px-3.5 py-2.5 text-sm text-text">
              <span class="text-accent-text">
                <Fragment set:html={icons.check} />
              </span>
              {t}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Compatibility / migration -->
  <section class="py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-wider text-accent-text">Migration</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-text md:text-4xl">
          Bring your existing collections.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          Lossless round-trips for the documented surface — including scripts and variables.
        </p>
      </div>

      <div class="mx-auto mt-10 flex max-w-3xl flex-wrap items-center justify-center gap-2">
        {[
          'OpenAPI 3.x',
          'Swagger 2.0',
          'Postman v2.1',
          'Insomnia v4',
          'cURL',
          'WSDL',
          '.proto',
          'RAML 1.0',
          'SoapUI / ReadyAPI',
          'HAR',
        ].map((fmt) => (
          <span class="rounded-full border border-border bg-bg px-3.5 py-1.5 text-xs font-medium text-text-muted">
            {fmt}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Enterprise -->
  <section class="border-t border-border bg-bg-soft">
    <div class="mx-auto max-w-4xl px-6 py-20">
      <div class="rounded-2xl border border-border bg-bg p-8 md:p-10">
        <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
          <div class="md:flex-1">
            <div class="mb-2 inline-flex items-center gap-2 rounded-full border border-border bg-bg-soft px-3 py-1 text-xs font-medium text-text-muted">
              <Fragment set:html={icons.building} />
              For regulated industries
            </div>
            <h2 class="text-2xl font-semibold tracking-tight text-text md:text-3xl">
              Need enterprise support?
            </h2>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-text-muted md:text-base">
              The free binary is distributed as-is, with no maintenance or security-patch obligation. If your organization needs paid support, response-time SLAs, on-premise deployment assistance, training, or custom development — typical for banking, public sector, defense, healthcare, and regulated infrastructure — get in touch.
            </p>
          </div>
          <div class="shrink-0">
            <a
              href="https://github.com/apinizer/testnizer-releases/issues/new?labels=enterprise&title=Enterprise+support+inquiry"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-accent-hover"
            >
              Open an inquiry
              <Fragment set:html={icons.arrowRight} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-border">
    <div class="mx-auto max-w-4xl px-6 py-24 text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-text md:text-4xl">
        Free. No vendor lock-in. No subscription.
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-text-muted">
        Testnizer is built and maintained by Apinizer. There is no "pro" tier, no cloud workspace upsell, no waitlist for real features. We made it because we needed it ourselves.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href="/download"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-accent-hover"
        >
          Download Testnizer
          <Fragment set:html={icons.arrowRight} />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
