# Generated diagnostics bundles produced by `diagnostics:export`
testnizer-diagnostics-*.zip

# Generated third-party-licenses manifest (regenerated at packaging time)
resources/third-party-licenses.json

# Local Playwright trace dumps
**/trace.zip

# Local-only AI / dev tooling — kept on each maintainer's disk, never
# published. The repo is the MIT source; these are internal workflow files.
CLAUDE.md
.claude/

# Internal signing / release-ops runbook — kept on the maintainer's disk only
# (no secret values in it, but the signing process isn't published).
SIGNING.md

# Stray scaffolds occasionally created by `npx create-*` runs that
# misinterpret a flag (e.g. `--typescript`) as a target directory name.
website/--*

# Website (monorepo subdir) — build artifacts + its old standalone deploy
# workflow (GitHub only runs workflows from the repo-root .github/).
website/node_modules/
website/dist/
website/.astro/
website/.github/

# Bundled curl static binaries (F25 — legacy TLS sidecar).
# Per-platform static curl downloaded by `npm run download:curl` into
# resources/curl/{platform}-{arch}/. Not committed because they total
# ~18MB across the 6 release targets and would bloat clones. CI runs
# the prebuild:<target> npm script which fetches the right one before
# packaging.
resources/curl/

# Local scratchpad notes (commit only if explicitly intended).
todo_for_enterprise.md
